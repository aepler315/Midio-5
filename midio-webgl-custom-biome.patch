+/**
+ * BiomeImporter.js — Drag-and-drop MIDI → custom playable biome
+ * Reuses NoteEvent timeline + melody contour from companions
+ */
+export class BiomeImporter {
+  async handleDrop(e) {
+    const file = e.dataTransfer.files[0];
+    const events = await MidiAdapter.parseFile(file); // existing adapter
+    const custom = this.generateFromMelody(events);
+    ParamBus.set('customBiomes', [...ParamBus.get('customBiomes'), custom]);
+    Conductor.injectTimelineSlice(events); // single source of truth
+    // ARIA + toast feedback
+  }
+
+  generateFromMelody(events) {
+    return {
+      id: 'custom-' + Date.now(),
+      name: 'User MIDI Biome',
+      energyCurve: this.deriveEnergy(events),
+      parallaxCount: Math.min(8, events.length / 10 | 0),
+      fractureBase: this.deriveFracture(events),
+      colorPalette: this.derivePalette(events),
+      companionsBehaviors: 'melody-reactive'
+    };
+  }
+}
+
